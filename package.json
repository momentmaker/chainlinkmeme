    "og": "tsx scripts/build-og-images.ts",
    "weekly": "tsx scripts/build-weekly.ts",
    "discord:register": "tsx scripts/register-discord-command.ts",
    "telegram:register": "tsx scripts/register-telegram-webhook.ts",
