---
import '../styles/base.css';
import '../styles/theme-dark.css';
import { ClientRouter } from 'astro:transitions';

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
}

const { title, description, ogImage, canonical } = Astro.props;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://momentmaker.github.io';
const fullCanonical = canonical ?? siteUrl + Astro.url.pathname;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
// Emit og:image only when a real per-page image exists. The OG build step
// generates one per permalink; the home page will get a default hero later.
const fullOg = ogImage ?? null;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#2f62df" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={fullCanonical} />
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
    <link rel="icon" href={`${base}/favicon.ico`} sizes="32x32" />
    <link rel="apple-touch-icon" href={`${base}/apple-touch-icon.png`} />
    <link rel="manifest" href={`${base}/manifest.webmanifest`} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {fullOg && <meta property="og:image" content={fullOg} />}
    <meta property="og:url" content={fullCanonical} />
    <meta property="og:type" content="website" />

    <meta name={fullOg ? 'twitter:card' : 'twitter:card'} content={fullOg ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {fullOg && <meta name="twitter:image" content={fullOg} />}

    <script is:inline>
      // Apply stored theme before first paint to avoid FOUC
      (function () {
        try {
          const t = localStorage.getItem('chainlinkmeme:theme');
          if (t === 'dark') document.documentElement.dataset.theme = 'dark';
          else if (!t && window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
            document.documentElement.dataset.theme = 'dark';
          }
        } catch (e) { /* ignore */ }
      })();
    </script>

    <slot name="head-extra" />

    <ClientRouter fallback="animate" />

    <script
      is:inline
      src="https://beamanalytics.b-cdn.net/beam.min.js"
      data-token="31849e6a-ced4-4736-a35e-718f63f83486"
      async
    ></script>
  </head>
  <body>
    <slot name="progress" />
    <main class="page">
      <header class="header">
        <a class="brand" href={`${base}/`}>тмбтПгтмв chainlink meme тмвтПгтмб</a>
        <span class="tagline">cosmic memes by linkmarines, for chainlink</span>
        <div class="right">
          <slot name="header-actions" />
          <a href={`${base}/contribute/`} class="filter-pill">contribute</a>
        </div>
      </header>
      <slot />
      <footer class="footer">
        <slot name="footer-stats" />
        <p>
          community-curated archive тАФ <a href={`${base}/contribute/`}>submit a meme</a> ┬╖
          <a href="https://github.com/momentmaker/chainlinkmeme" target="_blank" rel="noopener">source on github</a>
        </p>
      </footer>
    </main>
  </body>
</html>
