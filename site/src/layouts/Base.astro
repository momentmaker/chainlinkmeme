---
import '../styles/base.css';
import '../styles/theme-dark.css';
import { ClientRouter } from 'astro:transitions';
import Shuffle from '../components/Shuffle';

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
}

const { title, description, ogImage, canonical } = Astro.props;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://momentmaker.github.io';
const fullCanonical = canonical ?? siteUrl + Astro.url.pathname;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const manifestHref = `${base}/manifest.json`;
// Emit og:image only when a real per-page image exists. The OG build step
// generates one per permalink; the home page will get a default hero later.
const fullOg = ogImage ?? null;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#2f62df" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={fullCanonical} />
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
    <link rel="icon" href={`${base}/favicon.ico`} sizes="32x32" />
    <link rel="apple-touch-icon" href={`${base}/apple-touch-icon.png`} />
    <link rel="manifest" href={`${base}/manifest.webmanifest`} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {fullOg && <meta property="og:image" content={fullOg} />}
    <meta property="og:url" content={fullCanonical} />
    <meta property="og:type" content="website" />

    <meta name="twitter:card" content={fullOg ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {fullOg && <meta name="twitter:image" content={fullOg} />}

    <script is:inline>
      // Apply stored theme before first paint to avoid FOUC, and re-apply
      // after every ClientRouter swap — Astro preserves <html> across
      // transitions but replaces its attributes, so data-theme would get
      // blown away on every navigation without this.
      (function () {
        function apply() {
          try {
            const t = localStorage.getItem('chainlinkmeme:theme');
            if (t === 'dark') document.documentElement.dataset.theme = 'dark';
            else if (t === 'light') document.documentElement.dataset.theme = 'light';
            else if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
              document.documentElement.dataset.theme = 'dark';
            }
          } catch (e) { /* ignore */ }
        }
        apply();
        document.addEventListener('astro:after-swap', apply);
      })();
    </script>

    <slot name="head-extra" />

    <ClientRouter fallback="animate" />

    <script
      is:inline
      defer
      src="https://analytics.jivx.com/script.js"
      data-website-id="9f897b85-fa34-4b13-9cee-27c23153b1b0"
    ></script>
  </head>
  <body>
    <slot name="progress" />
    <main class="page">
      <header class="header">
        <div class="brand-stack">
          <a class="brand" href={`${base}/`}>⬡⏣⬢ chainlink meme ⬢⏣⬡</a>
          <span class="tagline">cosmic memes by linkmarines, for chainlink</span>
        </div>
        <div class="right">
          <slot name="header-actions" />
          <a href={`${base}/map/`} class="hex-btn" aria-label="Tag constellation" title="Tag constellation — the archive as a cosmos">
            <span class="hex-btn-label">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 4 3 6v14l6-2m0-14 6 2m-6-2v14m6-12 6-2v14l-6 2m0-14v14"/></svg>
            </span>
          </a>
          <a href={`${base}/week/`} class="hex-btn" aria-label="Weekly top memes" title="Weekly top 7 memes">
            <span class="hex-btn-label">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M3 10h18M8 3v4M16 3v4"/></svg>
            </span>
          </a>
          <a href={`${base}/grid/`} class="hex-btn" aria-label="Honeycomb grid" title="Honeycomb — every meme as one hex tessellation">
            <span class="hex-btn-label">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 2 3 5v6l6 3 6-3V5l-6-3Z"/><path d="M15 11l6 3v6l-6 3-6-3v-6"/></svg>
            </span>
          </a>
        </div>
      </header>
      <slot />
      <Shuffle client:load manifestUrl={manifestHref} />
      <footer class="footer">
        <slot name="footer-stats" />
        <p>
          community-curated archive — <a href={`${base}/contribute/`}>submit a meme</a> ·
          <a href={`${base}/map/`}>tag map</a> ·
          <a href={`${base}/grid/`}>honeycomb</a> ·
          <a href={`${base}/week/`}>weekly</a> ·
          <a href="https://github.com/momentmaker/chainlinkmeme" target="_blank" rel="noopener">source on github</a>
        </p>
        <p class="kin">
          hex kin: <a href="https://fz.ax" target="_blank" rel="noopener">fz.ax</a>
        </p>
      </footer>
    </main>
  </body>
</html>
