---
import Base from '../layouts/Base.astro';
import Gallery, { ThemeToggle, ProgressBar, HexScrollTop } from '../components/Gallery';
import { memeOfDay } from '../lib/meme-of-day';
import { memeUrl, permalinkUrl } from '../lib/meme-url';
import type { Manifest } from '../lib/manifest';
import manifestJson from '../../public/manifest.json';

// Manifest is imported server-side *only* to pick the meme-of-the-day for the
// initial HTML. The Gallery component itself fetches /manifest.json at runtime
// so the full data doesn't get serialized into the hydration payload.
const manifest = manifestJson as Manifest;
const mod = memeOfDay(manifest.memes);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const manifestHref = `${base}/manifest.json`;

// Stats strip — computed at build time, shown once in the footer.
const lastUpdated = [...manifest.memes]
  .map((m) => m.date_added)
  .filter(Boolean)
  .sort()
  .pop() ?? '';
const stats = {
  memes: manifest.memes.length.toLocaleString(),
  tags: manifest.tags.length.toLocaleString(),
  lastUpdated,
};
---
<Base
  title="⬡⏣⬢ chainlink meme ⬢⏣⬡"
  description="community-curated archive of chainlink memes — browse, search by tag, favorite, share"
>
  <Fragment slot="head-extra">
    <link rel="preload" href={manifestHref} as="fetch" crossorigin="anonymous" />
  </Fragment>

  <ProgressBar client:load slot="progress" />
  <ThemeToggle client:load slot="header-actions" />

  {mod && (
    <a href={permalinkUrl(mod.slug)} class="hero" style="text-decoration: none; color: white;">
      <img class="hero-img" src={memeUrl(mod.filename)} alt={mod.title || mod.slug} />
      <div>
        <div class="hero-label">⬢ meme of the day</div>
        <div class="hero-title">{mod.title || mod.slug}</div>
        <div style="font-size: 12px; opacity: 0.8;">
          {mod.tags.slice(0, 6).join(' · ')}
        </div>
      </div>
    </a>
  )}

  <Gallery client:load manifestUrl={manifestHref} />

  <HexScrollTop client:load />

  <p class="stats-strip" slot="footer-stats">
    <span><strong>{stats.memes}</strong> memes</span>
    <span class="dot">⬡</span>
    <span><strong>{stats.tags}</strong> tags</span>
    <span class="dot">⬡</span>
    <span>last updated <strong>{stats.lastUpdated}</strong></span>
  </p>
</Base>

<script>
  // Cursor-reactive tilt + shine for the meme-of-the-day hero.
  // Vanilla JS keeps the payload tiny — no react island needed for this one.
  const hero = document.querySelector<HTMLElement>('.hero');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (hero && !reduce) {
    const MAX_TILT = 5;
    hero.addEventListener('mousemove', (e) => {
      const r = hero.getBoundingClientRect();
      const nx = (e.clientX - r.left) / r.width - 0.5;
      const ny = (e.clientY - r.top) / r.height - 0.5;
      hero.style.setProperty('--tilt-x', `${-ny * MAX_TILT}deg`);
      hero.style.setProperty('--tilt-y', `${nx * MAX_TILT}deg`);
      hero.style.setProperty('--shine-x', `${(nx + 0.5) * 100}%`);
      hero.style.setProperty('--shine-y', `${(ny + 0.5) * 100}%`);
      hero.style.setProperty('--shine-opacity', '1');
    });
    hero.addEventListener('mouseleave', () => {
      hero.style.setProperty('--tilt-x', '0deg');
      hero.style.setProperty('--tilt-y', '0deg');
      hero.style.setProperty('--shine-opacity', '0');
    });
  }
</script>
