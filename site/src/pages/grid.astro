---
import Base from '../layouts/Base.astro';
import { ThemeToggle } from '../components/Gallery';
import HexGrid from '../components/Grid';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const manifestHref = `${base}/manifest.json`;
---
<Base
  title="⬢ honeycomb — chainlink meme"
  description="Every meme in the archive as a single hex tessellation — zoom, pan, and click any tile to open it."
>
  <ThemeToggle client:load slot="header-actions" />
  <article class="map-page">
    <header class="map-header">
      <p class="weekly-eyebrow">⬢ honeycomb</p>
      <h1 class="map-title">the archive, tessellated</h1>
      <p class="map-sub">every meme as a hex · scroll to zoom · drag to pan · click a tile to open</p>
    </header>
    <HexGrid client:load manifestUrl={manifestHref} />
    <div class="map-footnote">
      <a href={`${base}/`} class="btn ghost">← back to gallery</a>
    </div>
  </article>
</Base>
