---
import Base from '../../layouts/Base.astro';
import { ThemeToggle } from '../../components/Gallery';

interface WeeklySnapshot {
  week: string;
  start: string;
  end: string;
  generated_at: string;
  top: Array<{ slug: string; total: number }>;
}

const modules = import.meta.glob<WeeklySnapshot>('../../data/weekly/*.json', { eager: true, import: 'default' });
const weeks = Object.values(modules).sort((a, b) => b.week.localeCompare(a.week));
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Base title="⬢ weekly stack — chainlink meme" description="The top 7 memes of every week, frozen in time.">
  <ThemeToggle client:load slot="header-actions" />
  <article class="weekly-index">
    <header class="weekly-header">
      <p class="weekly-eyebrow">⬢ weekly stack</p>
      <h1 class="weekly-title">all weeks</h1>
      <p class="weekly-range">7 most-reacted memes per ISO week. Snapshots freeze on Monday.</p>
    </header>
    {weeks.length === 0 ? (
      <p class="weekly-empty">No weeks snapshotted yet.</p>
    ) : (
      <ul class="weekly-index-list">
        {weeks.map((w) => (
          <li>
            <a href={`${base}/week/${w.week}/`}>
              <strong>{w.week}</strong>
              <span>{w.start} → {w.end}</span>
              <span class="weekly-index-total">{w.top.reduce((acc, r) => acc + r.total, 0)} reactions</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </article>
</Base>
