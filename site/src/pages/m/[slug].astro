---
import Base from '../../layouts/Base.astro';
import { ThemeToggle, PermalinkReactions } from '../../components/Gallery';
import { memeUrl, permalinkUrl } from '../../lib/meme-url';
import type { Manifest, MemeEntry } from '../../lib/manifest';
import manifestJson from '../../../public/manifest.json';

const manifest = manifestJson as Manifest;

export async function getStaticPaths() {
  const m = (await import('../../../public/manifest.json')) as { default: Manifest };
  return m.default.memes.map((meme) => ({
    params: { slug: meme.slug },
    props: { meme },
  }));
}

const { meme } = Astro.props as { meme: MemeEntry };
const related = manifest.memes
  .filter((m) => m.slug !== meme.slug && m.tags.some((t) => meme.tags.includes(t)))
  .slice(0, 6);

// Legacy imports inherit the md5-hex filename as a placeholder title. If the
// title looks like one of those, prefer the first tag (mirrors the OG card).
const HASH_RE = /^[0-9a-f]{10,}$/i;
const displayTitle = meme.title && !HASH_RE.test(meme.title)
  ? meme.title
  : (meme.tags[0] ? `#${meme.tags[0]}` : 'chainlink meme');

// Step through the archive in manifest order for next/prev navigation. Keeps
// the permalink experience symmetric with the modal's keyboard carousel.
const memes = manifest.memes;
const idx = memes.findIndex((m) => m.slug === meme.slug);
const prev = idx > 0 ? memes[idx - 1] : null;
const next = idx >= 0 && idx < memes.length - 1 ? memes[idx + 1] : null;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://chainlinkme.me';
// For animated memes (GIFs), unfurl the raw file so Discord/Telegram/
// WhatsApp preview it moving — the Satori-rendered PNG card kills
// animation. Static images keep the branded card. memeUrl() already
// returns a fully-qualified jsDelivr URL in prod.
const ogImage = meme.animated
  ? memeUrl(meme.filename)
  : `${siteUrl}/og/${meme.slug}.png`;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Base
  title={`${displayTitle} — chainlink meme`}
  description={meme.description || `${meme.tags.map((t) => '#' + t).join(' ')} — chainlink meme`}
  ogImage={ogImage}
>
  <ThemeToggle client:load slot="header-actions" />

  <article class="permalink">
    <div class="permalink-stage">
      <img
        class="permalink-img"
        src={memeUrl(meme.filename)}
        alt={meme.title || meme.slug}
        style={`view-transition-name: meme-${meme.slug};`}
      />
      <!-- Copy-link hex — mirrors the gallery card's top-right action slot. -->
      <div class="permalink-overlay-top-right">
        <button
          type="button"
          class="card-link"
          data-permalink
          aria-label="Copy permalink"
          title="Copy permalink"
        >
          <span class="card-link-icon" aria-hidden="true">🔗</span>
        </button>
      </div>
      <!-- Reactions island — hydrates in-place; matches the card's overlay. -->
      <PermalinkReactions client:load slug={meme.slug} />
    </div>
    <div class="permalink-meta">
      <h1 class="permalink-title">{displayTitle}</h1>
      {meme.description && <p class="permalink-description">{meme.description}</p>}
      <div class="permalink-tags">
        {meme.tags.map((t) => (
          <a href={`${base}/?q=${encodeURIComponent(t)}`} class="tag-chip">#{t}</a>
        ))}
      </div>
      {(meme.credit || meme.submitted_by || meme.source_url) && (
        <p class="permalink-credit">
          {meme.credit && <>credit: {meme.credit}</>}
          {meme.credit && (meme.submitted_by || meme.source_url) && ' · '}
          {meme.submitted_by && (
            <>submitted by <a href={`https://github.com/${meme.submitted_by.replace(/^@/, '')}`}>{meme.submitted_by}</a></>
          )}
          {meme.submitted_by && meme.source_url && ' · '}
          {meme.source_url && <a href={meme.source_url} rel="noopener">source</a>}
        </p>
      )}
      <div class="permalink-actions">
        <button type="button" class="btn ghost" data-download data-url={memeUrl(meme.filename)} data-filename={meme.filename}>download</button>
        <button type="button" class="btn ghost" data-sticker data-url={memeUrl(meme.filename)} data-slug={meme.slug} data-animated={meme.animated ? '1' : '0'}>save as sticker</button>
        <button type="button" class="btn ghost" data-embed data-embed-url={`${siteUrl}${base}/embed/${meme.slug}/`} data-permalink-url={`${siteUrl}${Astro.url.pathname}`} data-slug={meme.slug}>copy embed</button>
        <a class="btn ghost"
           href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(displayTitle + ' — chainlinkme.me')}&url=${encodeURIComponent(siteUrl + Astro.url.pathname)}`}
           target="_blank" rel="noopener">share →</a>
      </div>

      <nav class="permalink-nav">
        {prev ? (
          <a class="btn ghost" href={permalinkUrl(prev.slug)}>← previous</a>
        ) : <span class="btn ghost" aria-disabled="true" style="opacity:0.3">← previous</span>}
        <a class="btn ghost" href={`${base}/`}>gallery</a>
        {next ? (
          <a class="btn ghost" href={permalinkUrl(next.slug)}>next →</a>
        ) : <span class="btn ghost" aria-disabled="true" style="opacity:0.3">next →</span>}
      </nav>
    </div>

    {related.length > 0 && (
      <section class="related-section">
        <h2 class="related-heading">⬢ related memes</h2>
        <div class="gallery">
          {related.map((r) => (
            <a href={permalinkUrl(r.slug)} class="card">
              <img src={memeUrl(r.filename)} alt={r.title || r.slug} loading="lazy" />
            </a>
          ))}
        </div>
      </section>
    )}
  </article>

  <script>
    // Bundled scripts run once per hard load; with Astro ClientRouter,
    // navigating between permalinks swaps the DOM without re-executing
    // module scripts. Re-binding on astro:page-load (which also fires
    // on initial load) keeps copy-link and download working on every
    // permalink visit.
    function wirePermalinkActions() {
      const copyBtn = document.querySelector<HTMLButtonElement>('[data-permalink]');
      if (copyBtn && !copyBtn.dataset.bound) {
        copyBtn.dataset.bound = '1';
        const icon = copyBtn.querySelector<HTMLElement>('.card-link-icon');
        const defaultIcon = icon?.textContent ?? '🔗';
        copyBtn.addEventListener('click', async (e) => {
          e.preventDefault();
          e.stopPropagation();
          try {
            await navigator.clipboard.writeText(window.location.href);
            if (icon) { icon.textContent = '✓'; }
            setTimeout(() => { if (icon) icon.textContent = defaultIcon; }, 1500);
          } catch {
            if (icon) { icon.textContent = '✗'; }
            setTimeout(() => { if (icon) icon.textContent = defaultIcon; }, 1500);
          }
        });
      }

      // Cross-origin download: browsers ignore the `download` attribute
      // when the href points to a different origin (jsDelivr), so fetch
      // the image as a blob and trigger the save dialog through a
      // temporary object-URL link. Falls back to opening the image in a
      // new tab if the cross-origin fetch is blocked.
      const dlBtn = document.querySelector<HTMLButtonElement>('[data-download]');
      if (dlBtn && !dlBtn.dataset.bound) {
        dlBtn.dataset.bound = '1';
        dlBtn.addEventListener('click', async () => {
          const url = dlBtn.dataset.url;
          const filename = dlBtn.dataset.filename;
          if (!url || !filename) return;
          const w = window as unknown as { umami?: { track: (n: string, d?: Record<string, unknown>) => void } };
          w.umami?.track('meme-download', { filename });
          const original = dlBtn.textContent ?? 'download';
          dlBtn.textContent = 'preparing…';
          dlBtn.disabled = true;
          try {
            const res = await fetch(url, { mode: 'cors' });
            if (!res.ok) throw new Error(`HTTP ${res.status}`);
            const blob = await res.blob();
            const objUrl = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = objUrl;
            a.download = filename;
            document.body.appendChild(a);
            a.click();
            a.remove();
            setTimeout(() => URL.revokeObjectURL(objUrl), 1000);
            dlBtn.textContent = '✓ saved';
          } catch {
            window.open(url, '_blank', 'noopener');
            dlBtn.textContent = 'opened in new tab';
          } finally {
            setTimeout(() => {
              dlBtn.textContent = original;
              dlBtn.disabled = false;
            }, 1500);
          }
        });
      }
    }

    // Save-as-sticker: hand off to the sticker encoder module, which is
    // dynamically imported so its UPNG + pako bundle (~95KB) only loads
    // when a user clicks. Static images → 512×512 WebP; animated GIFs →
    // 512×512 APNG (covers Discord, Signal, generic web embed).
    function wireSticker() {
      const btn = document.querySelector<HTMLButtonElement>('[data-sticker]');
      if (!btn || btn.dataset.bound) return;
      btn.dataset.bound = '1';
      btn.addEventListener('click', async () => {
        const url = btn.dataset.url;
        const slug = btn.dataset.slug;
        const animated = btn.dataset.animated === '1';
        if (!url || !slug) return;
        const original = btn.textContent ?? 'save as sticker';
        btn.textContent = 'preparing…';
        btn.disabled = true;
        const w = window as unknown as { umami?: { track: (n: string, d?: Record<string, unknown>) => void } };
        w.umami?.track('sticker-save', { slug, animated });
        // Oversize messages are long ("saved (489KB — over 293KB limit)")
        // and users need to read them; give them more time on screen.
        let resetMs = 1800;
        try {
          const mod = await import('../../lib/sticker');
          const { oversize, blob, maxBytes } = await mod.saveAsSticker({ url, slug, animated });
          if (oversize) {
            const kb = Math.round(blob.size / 1024);
            const limitKb = Math.round(maxBytes / 1024);
            btn.textContent = `saved (${kb}KB — over ${limitKb}KB limit)`;
            w.umami?.track('sticker-oversize', { slug, kb, limitKb });
            resetMs = 4500;
          } else {
            btn.textContent = animated ? '✓ saved (apng)' : '✓ saved';
          }
        } catch (err) {
          // Most likely culprit: a CDN edge stripped CORS headers so the
          // canvas is tainted and toBlob throws SecurityError. Surface it
          // to umami so we can see if this becomes a real user-facing
          // issue rather than a theoretical one.
          const reason = err instanceof Error ? err.name : 'unknown';
          w.umami?.track('sticker-fail', { slug, reason });
          btn.textContent = 'sticker failed';
        } finally {
          setTimeout(() => { btn.textContent = original; btn.disabled = false; }, resetMs);
        }
      });
    }

    // Cursor-reactive 3D tilt for the permalink image — same language as the
    // home hero. Skipped on touch devices (no hover) and for reduced-motion
    // users. Re-binds on astro:page-load since ClientRouter swaps bodies
    // without re-running this module script.
    function wirePermalinkTilt() {
      const stage = document.querySelector<HTMLElement>('.permalink-stage');
      if (!stage || stage.dataset.tiltBound === '1') return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      if (window.matchMedia('(hover: none)').matches) return;
      stage.dataset.tiltBound = '1';
      const MAX_TILT = 4;
      stage.addEventListener('mousemove', (e) => {
        const r = stage.getBoundingClientRect();
        const nx = (e.clientX - r.left) / r.width - 0.5;
        const ny = (e.clientY - r.top) / r.height - 0.5;
        stage.style.setProperty('--tilt-x', `${-ny * MAX_TILT}deg`);
        stage.style.setProperty('--tilt-y', `${nx * MAX_TILT}deg`);
        stage.style.setProperty('--shine-x', `${(nx + 0.5) * 100}%`);
        stage.style.setProperty('--shine-y', `${(ny + 0.5) * 100}%`);
        stage.style.setProperty('--shine-opacity', '1');
      });
      stage.addEventListener('mouseleave', () => {
        stage.style.setProperty('--tilt-x', '0deg');
        stage.style.setProperty('--tilt-y', '0deg');
        stage.style.setProperty('--shine-opacity', '0');
      });
    }

    function wireEmbed() {
      const btn = document.querySelector<HTMLButtonElement>('[data-embed]');
      if (!btn || btn.dataset.bound) return;
      btn.dataset.bound = '1';
      btn.addEventListener('click', async () => {
        const embedUrl = btn.dataset.embedUrl;
        const permalinkUrl = btn.dataset.permalinkUrl;
        const slug = btn.dataset.slug;
        if (!embedUrl || !permalinkUrl) return;
        const original = btn.textContent ?? 'copy embed';
        const snippet = `<iframe src="${embedUrl}" width="500" height="500" frameborder="0" loading="lazy" title="chainlink meme ${slug ?? ''}" style="border:0;max-width:100%"></iframe>`;
        try {
          await navigator.clipboard.writeText(snippet);
          const w = window as unknown as { umami?: { track: (n: string, d?: Record<string, unknown>) => void } };
          w.umami?.track('embed-copy', { slug });
          btn.textContent = '✓ copied embed code';
        } catch {
          btn.textContent = '✗ copy failed';
        }
        setTimeout(() => { btn.textContent = original; }, 1800);
      });
    }

    wirePermalinkActions();
    wireSticker();
    wireEmbed();
    wirePermalinkTilt();
    document.addEventListener('astro:page-load', () => {
      wirePermalinkActions();
      wireSticker();
      wireEmbed();
      wirePermalinkTilt();
    });
  </script>
</Base>
